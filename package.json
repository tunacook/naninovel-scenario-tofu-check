{
  "name": "naninovel-atlas-tofu-check",
  "version": "0.0.0",
  "description": "NaninovelのシナリオファイルにおいてTextMeshProのFontAtlasに含まれていない文字があるかどうかチェックする",
  "main": "index.ts",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "lint": "yarn eslint && yarn prettier",
    "lint-fix": "yarn eslint --fix && yarn prettier-fix",
    "prettier-fix": "prettier --write \"./**/*.{ts,js,vue,css}\"",
    "prettier": "prettier --check \"./**/*.{ts,js,vue,css}\"",
    "test": "yarn jest"
  },
  "repository": "git@github.com:tunacook/naninovel-atlas-tofu-check.git",
  "author": "tunacook <tunacook0704@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "naninovel-script-spec": "github:tunacook/naninovel-script-spec#latest",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@vercel/ncc": "^0.44.1",
    "eslint": "^10.4.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "typescript-eslint": "^8.60.1"
  }
}
